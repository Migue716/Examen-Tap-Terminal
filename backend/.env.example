APP_NAME="Tap Terminal"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:4200

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mongodb
# MongoDB local (Windows/Linux): puerto 27017
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DATABASE=tapterminal

# Mailpit en local: docker compose up -d mailpit  →  http://localhost:8025
MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_TIMEOUT=10
MAIL_FROM_ADDRESS=noreply@tapterminal.com
MAIL_FROM_NAME="${APP_NAME}"

# Alternativa sin Mailpit: MAIL_MAILER=log (correos en storage/logs/laravel.log)

SANCTUM_STATEFUL_DOMAINS=localhost,localhost:4200,127.0.0.1,127.0.0.1:4200

L5_SWAGGER_GENERATE_ALWAYS=true
L5_SWAGGER_CONST_HOST=http://localhost:8000/api
